<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="2"
    android:rowCount="2"
    android:padding="8dp">

    <Button
        android:id="@+id/main_6_6_board"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="8dp"
        android:text="6 X 6"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5600E8"
        app:icon="@drawable/baseline_music_note_24"
        app:iconTint="#C6A8FF"
        app:iconGravity="textTop"
        app:iconSize="48dp"
        app:cornerRadius="0dp"
        android:tag="6 6"
        android:onClick="onBoardSizeClick"/>

    <Button
        android:id="@+id/main_4_4_board"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="8dp"
        android:text="4 X 4"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5600E8"
        app:icon="@drawable/baseline_music_note_24"
        app:iconTint="#C6A8FF"
        app:iconGravity="textTop"
        app:iconSize="48dp"
        app:cornerRadius="0dp"
        android:tag="4 4"
        android:onClick="onBoardSizeClick"/>

    <Button
        android:id="@+id/main_4_3_board"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="8dp"
        android:text="4 X 3"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5600E8"
        app:icon="@drawable/baseline_music_note_24"
        app:iconTint="#C6A8FF"
        app:iconGravity="textTop"
        app:iconSize="48dp"
        app:cornerRadius="0dp"
        android:tag="4 3"
        android:onClick="onBoardSizeClick"/>


    <Button
        android:id="@+id/main_3_2_board"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="8dp"
        android:text="3 X 2"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5600E8"
        app:icon="@drawable/baseline_music_note_24"
        app:iconTint="#C6A8FF"
        app:iconGravity="textTop"
        app:iconSize="48dp"
        app:cornerRadius="0dp"
        android:tag="3 2"
        android:onClick="onBoardSizeClick"/>

</GridLayout>